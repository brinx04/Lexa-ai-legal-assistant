# ── Lexa root environment — copy to .env and fill in ─────────────────────────
# Used by: docker-compose interpolation, FastAPI, Celery worker.

# Postgres (compose maps container 5432 → host 5433)
POSTGRES_USER=lexa_admin
POSTGRES_PASSWORD=change-me
POSTGRES_DB=lexa_db
POSTGRES_HOST=localhost
POSTGRES_PORT=5433

# Redis (compose maps container 6379 → host 6380)
REDIS_PASSWORD=change-me
REDIS_HOST=localhost
REDIS_PORT=6380

# Qdrant vector DB
QDRANT_URL=http://localhost:6335

# Google Gemini (https://aistudio.google.com/apikey)
GEMINI_API_KEY=your-gemini-api-key

# Shared secret between the Next.js proxy and FastAPI — generate a long
# random string, e.g.:  openssl rand -hex 32
LEXA_SECRET_API_KEY=generate-a-long-random-string

# Indian Kanoon API (https://api.indiankanoon.org) — optional
KANOON_API_TOKEN=

# ── Event streaming (Kafka) ───────────────────────────────────────────────────
# Host-run backend talks to the EXTERNAL listener; containers use kafka:9092.
KAFKA_ENABLED=true
KAFKA_BOOTSTRAP_SERVERS=localhost:9094

# ── Observability ─────────────────────────────────────────────────────────────
OTEL_ENABLED=true
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
GRAFANA_ADMIN_PASSWORD=admin

# ── Only needed for `docker compose --profile full` (containerized frontend) ──
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32
GOOGLE_CLIENT_ID=your-oauth-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-oauth-client-secret
