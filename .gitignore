# ──────────────────────────────────────────────
# Python / Backend
# ──────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg
*.egg-info/
dist/
build/
.eggs/
*.so

# Virtual environments
.venv/
venv/
env/
ENV/

# Environment variables
.env
.env.*

# Uploads (user files, not source code)
backend/uploads/

# ──────────────────────────────────────────────
# Node / Frontend (Next.js)
# ──────────────────────────────────────────────
node_modules/
frontend/node_modules/
frontend/.next/
frontend/out/
frontend/build/

# Next.js auto-generated
*.tsbuildinfo
next-env.d.ts

# Environment variables
frontend/.env*

# ──────────────────────────────────────────────
# Editor / OS
# ──────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# ──────────────────────────────────────────────
# Logs & Debug
# ──────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ──────────────────────────────────────────────
# Misc
# ──────────────────────────────────────────────
*.pem
.vercel
coverage/

# ──────────────────────────────────────────────
# Committed templates (negate the .env ignores)
# ──────────────────────────────────────────────
!.env.example
!frontend/.env.local.example

# Kubernetes secrets with real values
k8s/02-secrets.yaml

# Go build artifacts
notifier/notifier
notifier/*.exe
notifier/go.sum

# Local AI tooling config (never commit)
.claude/
