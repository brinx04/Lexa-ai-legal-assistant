{
  "title": "Lexa — System Overview",
  "uid": "lexa-overview",
  "tags": ["lexa"],
  "timezone": "browser",
  "schemaVersion": 39,
  "refresh": "10s",
  "time": { "from": "now-30m", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "API request rate (req/s by handler)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum by (handler) (rate(http_requests_total{job=\"lexa-api\"}[2m]))",
          "legendFormat": "{{handler}}"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "API latency p95 (s)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, handler) (rate(http_request_duration_seconds_bucket{job=\"lexa-api\"}[5m])))",
          "legendFormat": "{{handler}}"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Kafka events consumed (events/s by type)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "sum by (event_type) (rate(lexa_notifier_events_consumed_total[2m]))",
          "legendFormat": "{{event_type}}"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Live SSE clients",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 8 },
      "targets": [{ "expr": "sum(lexa_notifier_sse_clients)" }]
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Consumer lag",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 8 },
      "targets": [{ "expr": "sum(lexa_notifier_kafka_consumer_lag)" }],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 100 },
              { "color": "red", "value": 1000 }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 6,
      "type": "stat",
      "title": "Dead-letter messages",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 12 },
      "targets": [{ "expr": "sum(lexa_notifier_dlq_messages_total)" }],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 7,
      "type": "stat",
      "title": "Events delivered to browsers",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 12 },
      "targets": [{ "expr": "sum(lexa_notifier_events_delivered_total)" }]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "API 5xx errors (req/s)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{job=\"lexa-api\", status=~\"5..\"}[2m]))",
          "legendFormat": "5xx"
        }
      ]
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "API in-flight requests",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "targets": [
        {
          "expr": "sum(http_requests_in_progress{job=\"lexa-api\"})",
          "legendFormat": "in-flight"
        }
      ]
    }
  ]
}
